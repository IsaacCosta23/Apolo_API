# ============================================================================
# APOLO CODEXAI API - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values for the target environment
# $ cp .env.example .env
# ============================================================================

# ============================================================================
# ENVIRONMENT & PORT
# ============================================================================
# NODE_ENV: development | staging | production
NODE_ENV=development

# PORT: API server port (default: 8000)
PORT=8000


# ============================================================================
# DATABASE - OPTION 1: SUPABASE (RECOMMENDED FOR PRODUCTION)
# ============================================================================
# Use Supabase for managed PostgreSQL with built-in Auth, Storage, etc.
# URL format: postgresql://user:password@host:port/database?sslmode=require

# Get from: https://supabase.com/dashboard/project/[project-id]/settings/database
# Under "Connection String" tab, select "URI"
SUPABASE_DB_URL=postgresql://postgres:password@db.PROJECT-ID.supabase.co:5432/postgres?sslmode=require

# Supabase API credentials (for future Auth integration)
# Get from: https://supabase.com/dashboard/project/[project-id]/settings/api
SUPABASE_URL=https://PROJECT-ID.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ============================================================================
# DATABASE - OPTION 2: RENDER (COMPATIBLE)
# ============================================================================
# Use for PostgreSQL on Render or other managed PostgreSQL services
# Leave empty if using SUPABASE_DB_URL above

# DATABASE_URL=postgresql://user:password@host:port/database


# ============================================================================
# DATABASE - OPTION 3: SQLITE LOCAL (DEVELOPMENT ONLY)
# ============================================================================
# Used automatically if SUPABASE_DB_URL and DATABASE_URL are empty
# DATABASE_URL=sqlite:///./apolo_codex.db


# ============================================================================
# MAPBOX CONFIGURATION (FOR FRONTEND - MAPS & GEOLOCATION)
# ============================================================================
# Get token from: https://account.mapbox.com/auth/signin/
# Create token with scopes: MAPS:READ, STYLES:READ, GEOCODING:READ
# Required for map functionality on frontend

MAPBOX_TOKEN=pk.eyJ1IjoieW91ciIsImEiOiJjbHgxMjM0NTYifQ.YOUR-TOKEN-HERE


# ============================================================================
# CORS - ALLOWED ORIGINS
# ============================================================================
# Comma-separated list of allowed origins
# Local origins (localhost, 127.0.0.1) are included automatically
# Add production URLs here when deploying

CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173


# ============================================================================
# FRONTEND API BASE
# ============================================================================
# Base URL for API calls from frontend
# Leave empty for local development (frontend and API on same domain)
# Set to production URL when deploying (e.g., https://api.seu-app.com)

FRONTEND_API_BASE=


# ============================================================================
# RENDER DEPLOYMENT (ONLY IF USING RENDER)
# ============================================================================
# Render sets this automatically. For local testing, leave empty or false.
# RENDER=false


# ============================================================================
# SUPABASE SETUP GUIDE
# ============================================================================
#
# 1. Create Supabase project: https://supabase.com
#
# 2. Get Database Connection String:
#    - Go to: Settings > Database > Connection Pooling
#    - Select "Connection String" tab
#    - Choose "URI" format (not "psql")
#    - Copy the postgresql:// string
#    - Set as SUPABASE_DB_URL in this file
#
# 3. Get API Credentials:
#    - Go to: Settings > API
#    - Copy "Project URL" → SUPABASE_URL
#    - Copy "anon public" key → SUPABASE_ANON_KEY
#    - Copy "service_role secret" key → SUPABASE_SERVICE_ROLE_KEY
#
# 4. Mapbox Token:
#    - Create account: https://account.mapbox.com
#    - Create access token with MAPS:READ, STYLES:READ scopes
#    - Set as MAPBOX_TOKEN in this file
#
# 5. Start application:
#    $ cp .env.example .env
#    $ # Edit .env with your values
#    $ python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
#
# 6. Verify database connection:
#    $ curl http://localhost:8000/api/health
#
# ============================================================================
