# Database Configuration (use SQLite for local development)
DATABASE_URL=sqlite:///./apolo_codex.db

# For PostgreSQL in production, use:
# DATABASE_URL=postgresql://user:password@host:port/database

# Mapbox API Token (get from https://account.mapbox.com/)
MAPBOX_TOKEN=your_mapbox_token_here

# Node Environment
NODE_ENV=development

# Server Port
PORT=8000

# Frontend API Base URL (leave empty for local development)
FRONTEND_API_BASE=

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
